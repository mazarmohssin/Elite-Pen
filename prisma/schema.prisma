generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String
  image     String   // URL from Vercel Blob
  language  String   // Arabic, English, French, Spanish
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

